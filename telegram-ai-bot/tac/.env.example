# ======================================================================
# TAC (Twilio Agent Connect) 参照実装の環境変数
# 認証情報はすべて任意。未設定なら該当機能は安全に degrade します。
# ======================================================================

# --- LLM（顧客インフラ側の推論：設計図の「推論ループ」） ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-opus-4-8
# 要約/言語演算子だけ別モデルにしたい場合（既定は CLAUDE_MODEL と同じ）
# TAC_OPERATOR_MODEL=claude-opus-4-8
# 通話は低遅延優先: low | medium | high | max
CLAUDE_EFFORT=low
CLAUDE_MAX_TOKENS=400
# 最先端の回答用: サーバーサイド Web 検索（最新情報に対応）。
# 有効化すると、料金・時事・最新仕様などをモデルが必要時に調べて回答する。
# web_search_20260209 は Opus 4.8/4.7/4.6・Sonnet 4.6 で利用可（Haiku は不可）。
TAC_WEB_SEARCH=false
# TAC_WEB_SEARCH_TYPE=web_search_20260209
# TAC_WEB_SEARCH_MAX_USES=3

# LLM プロバイダ切替: anthropic（既定・Claude）/ openai（OpenAI 互換 API）
# openai にすると Ollama / vLLM / LM Studio などローカル/オープンモデルで動く。
# ※ オープンモデル経路は会話応答に特化（Claude 専用のツール・Web 検索は不可）。
TAC_LLM_PROVIDER=anthropic
# 例: Ollama をローカルで動かす場合
# TAC_LLM_PROVIDER=openai
# TAC_OPENAI_BASE_URL=http://localhost:11434/v1
# TAC_OPENAI_MODEL=qwen2.5      # 軽量化: llama3.1 / 高品質: qwen2.5:14b
# TAC_OPENAI_API_KEY=ollama

# --- Twilio 認証（Conversations / Studio / Flex） ---
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
# Conversations(Classic) サービス SID（オーケストレーター連携で使用）
TWILIO_CONVERSATIONS_SERVICE_SID=ISxxxxxxxx
# 「Agent Handoff」テンプレートで作成した Studio フローの SID
TWILIO_STUDIO_HANDOFF_FLOW_SID=FWxxxxxxxx
# SMS/チャットの Studio Execution 起動に使う発信元番号/送信者
TWILIO_HANDOFF_FROM=+18005550100
# Flex/TaskRouter ワークフロー SID（WWxxxx）。設定すると音声ハンドオフで
# ライブ通話を <Enqueue> でこのワークフローへ直接転送し、担当者へつなぐ。
TWILIO_FLEX_WORKFLOW_SID=WWxxxxxxxx

# --- Memory / Enterprise Knowledge（任意：未設定ならローカル/インメモリ） ---
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
OPENAI_API_KEY=sk-...   # ナレッジ意味検索の埋め込み用

# --- 挙動 ---
# true で外部呼び出しを実行せずペイロードのみ返す（デモ/テスト）
TAC_DRY_RUN=false
# Script Adherence オペレーターが評価する応対スクリプト/ポリシー
# TAC_AGENT_SCRIPT=冒頭で社名を名乗り、本人確認を行い、最後に要点を復唱して確認する。
AGENT_PERSONA=あなたは礼儀正しく、的確で、共感的なカスタマーサポート担当です。

# --- 音声 TwiML（server.py） ---
TWILIO_VOICE=Polly.Takumi-Neural
TWILIO_VOICE_LANG=ja-JP
TWILIO_SPEECH_MODEL=experimental_conversations
# 発話終了の無音待ち（秒）。auto はやや長め。1 前後でテンポUP
TWILIO_SPEECH_TIMEOUT=auto
PORT=8090

# --- ConversationRelay（双方向ストリーミング音声・最も人間らしい） ---
# 番号の Voice Webhook を /tac/voice-relay に向けると有効。flask-sock が必要。
# 既定は Google 最上位 Chirp3-HD（超自然）。英語化する場合は Neural2-B に戻す。
# TAC_RELAY_TTS_PROVIDER=Google
# TAC_RELAY_VOICE=ja-JP-Chirp3-HD-Aoede      # 代替: ja-JP-Neural2-B
# TAC_RELAY_WELCOME=お電話ありがとうございます。さくらです。ご用件をうかがいます。

# 御社の実情報（営業時間・料金・商品・FAQ 等）。指定するとさくらが正確に回答。
# tac/business_info.example.md をコピーして実情報に置き換え、パスを指定。
# TAC_BUSINESS_INFO_FILE=/Users/you/telegram-ai-bot/tac/business_info.md
