# Telegram の BotFather から取得したトークン
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Anthropic (Claude) API キー
ANTHROPIC_API_KEY=sk-ant-...

# --- 以下は任意 (デフォルト値あり) ---
# 使用する Claude モデル
CLAUDE_MODEL=claude-opus-4-8
# 思考の深さ: low | medium | high | max
CLAUDE_EFFORT=medium
# 1 応答あたりの最大トークン
CLAUDE_MAX_TOKENS=4096
# 保持する会話ターン数
HISTORY_TURNS=12
# システムプロンプト
# SYSTEM_PROMPT=あなたは親切なAIアシスタントです。
# シングルインスタンスロックのパス
BOT_LOCK_PATH=/tmp/telegram-ai-bot.lock

# ======================================================================
# Telegram → Claude Code ブリッジ (claude_code_bridge.py) 用
# ======================================================================
# Claude Code を操作できる Telegram ユーザーID（カンマ区切り・必須）
# 取得: Telegram で @userinfobot に話しかけると自分の数値IDが分かる
ALLOWED_TELEGRAM_USER_IDS=123456789
# Claude Code が作業するディレクトリ（既定: カレント）
CLAUDE_CODE_CWD=/home/user/your-project
# 権限モード: default | acceptEdits | plan | bypassPermissions
CLAUDE_CODE_PERMISSION_MODE=acceptEdits
# 許可ツール（カンマ区切り）
CLAUDE_CODE_ALLOWED_TOOLS=Read,Edit,Write,Bash,Glob,Grep
# 最大エージェントターン数
CLAUDE_CODE_MAX_TURNS=30
# 任意: Claude Code のモデル上書き
# CLAUDE_CODE_MODEL=claude-opus-4-8

# ======================================================================
# Slack 連携 (送信 / 読込 / /slack キーワード検索 / /semsearch セマンティック検索)
# ======================================================================
# Bot Token (xoxb-)。投稿・チャンネル履歴の取得・/slack のフォールバック検索・
# slack_sync.py が conversations.history を引くのに使用。
SLACK_BOT_TOKEN=xoxb-...
# User OAuth Token (xoxp-, search:read 付き)。/slack の全 WS 検索 (search.messages API) に必須。
# 取得: Slack App → OAuth & Permissions → User Token Scopes に search:read を追加
# →「Install App to Workspace」で再インストール → User OAuth Token をコピー
# SLACK_USER_TOKEN=xoxp-...
# 任意: /slack と /semsearch の要約に使う Claude モデル (デフォルト: Haiku 4.5)
# SLACK_SEARCH_SUMMARY_MODEL=claude-haiku-4-5-20251001
# 任意: /slack の 1 クエリあたりの上限ヒット数 (デフォルト: 20)
# SLACK_SEARCH_MAX_HITS=20

# ======================================================================
# Slack → Supabase 同期 + /semsearch セマンティック検索 (Track C)
# ======================================================================
# 同期ワーカー (slack_sync.py) と /semsearch ハンドラの両方が読む。
# Supabase プロジェクト URL (ダッシュボード → Project Settings → API)
SUPABASE_URL=https://xpzrsljqjhqewquaziul.supabase.co
# service_role キー (ダッシュボード → Project Settings → API → service_role secret)
# RLS をバイパスするので絶対公開しない
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1Nik...
# OpenAI API キー (text-embedding-3-small 用)
OPENAI_API_KEY=sk-...
# 任意: embedding モデルの上書き
# EMBEDDING_MODEL=text-embedding-3-small
# 任意: /semsearch の類似度閾値 (0.0-1.0)
# SEMSEARCH_THRESHOLD=0.4
# 任意: /semsearch の上位件数
# SEMSEARCH_TOP_K=10
