# BC自動生成サービス 環境設定サンプル
# 使い方: cp .env.example .env して値を埋め、`set -a; . ./.env; set +a` で読み込む
# （または launchd の EnvironmentVariables に設定）。.env はコミットしないこと。

# ── Claude（/extract で使用。/generate だけなら不要）──────────────
# Anthropic APIキー
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# 社内 LiteLLM プロキシ経由にする場合のみ設定（既定は本家 https://api.anthropic.com）
# ANTHROPIC_BASE_URL=http://localhost:4001
# 抽出に使うモデル（既定 claude-opus-4-8）
CLAUDE_MODEL=claude-opus-4-8
# 抽出の最大トークン（既定 4000）
CLAUDE_MAX_TOKENS=4000

# ── サービス ─────────────────────────────────────────────────
# 待受ポート（既定 8800）
BC_PORT=8800
# 本番ワークブック（36-1.xlsx / 37-1.xlsx / 38-1.xlsx）を置くディレクトリ（既定 templates）
# ここに御社のワークブックを <variant>.xlsx の名前で配置する。リポジトリには含めない。
BC_TEMPLATE_DIR=templates
