SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-level-token

OUTPUT_DIR=./output

# 許可するSlackユーザーID（カンマ区切り、空ならすべて許可）
# 例: U01ABCD1234,U02EFGH5678
ALLOWED_USERS=

# 許可するチャンネルID（カンマ区切り、空ならすべてのチャンネル）
# 例: C01ABCD1234
ALLOWED_CHANNELS=

# 生成ログを通知する管理チャンネルID（空なら通知しない）
# ボットをそのチャンネルに招待しておく必要があります
ADMIN_CHANNEL=
